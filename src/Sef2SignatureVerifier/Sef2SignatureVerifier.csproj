<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>DatPlayer.Sef2SignatureVerifier</AssemblyName>
    <RootNamespace>DatPlayer.Sef2SignatureVerifier</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\resources\Sef2SigningPublicKey.xml"
                      LogicalName="Sef2SigningPublicKey.xml" />
    <PackageReference Include="System.Security.Cryptography.Xml" Version="10.0.8" />
  </ItemGroup>
</Project>
